{
    "name": "@mtcute/core",
    "type": "module",
    "version": "0.30.1",
    "description": "Type-safe library for MTProto (Telegram API)",
    "license": "MIT",
    "scripts": {},
    "dependencies": {
        "@fuman/io": "0.0.19",
        "@fuman/net": "0.0.19",
        "@fuman/utils": "0.0.19",
        "@mtcute/file-id": "^0.29.0",
        "@mtcute/tl-runtime": "^0.29.0",
        "@types/events": "3.0.0",
        "long": "^5.3.2"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.ts",
                "default": "./index.js"
            },
            "require": {
                "types": "./index.d.cts",
                "default": "./index.cjs"
            }
        },
        "./utils.js": {
            "import": {
                "types": "./utils.d.ts",
                "default": "./utils.js"
            },
            "require": {
                "types": "./utils.d.cts",
                "default": "./utils.cjs"
            }
        },
        "./client.js": {
            "import": {
                "types": "./client.d.ts",
                "default": "./client.js"
            },
            "require": {
                "types": "./client.d.cts",
                "default": "./client.cjs"
            }
        },
        "./worker.js": {
            "import": {
                "types": "./worker.d.ts",
                "default": "./worker.js"
            },
            "require": {
                "types": "./worker.d.cts",
                "default": "./worker.cjs"
            }
        },
        "./methods.js": {
            "import": {
                "types": "./methods.d.ts",
                "default": "./methods.js"
            },
            "require": {
                "types": "./methods.d.cts",
                "default": "./methods.cjs"
            }
        },
        "./tl/api-schema.json": "./tl/api-schema.json",
        "./tl/app-config.json": "./tl/app-config.json",
        "./tl/raw-errors.json": "./tl/raw-errors.json",
        "./tl/mtp-schema.json": "./tl/mtp-schema.json"
    },
    "author": "alina sireneva <alina@tei.su>",
    "sideEffects": false,
    "homepage": "https://mtcute.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mtcute/mtcute.git"
    }
}