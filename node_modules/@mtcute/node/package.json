{
    "name": "@mtcute/node",
    "type": "module",
    "version": "0.30.1",
    "description": "Meta-package for Node.js",
    "license": "MIT",
    "dependencies": {
        "@mtcute/core": "^0.30.1",
        "@mtcute/html-parser": "^0.30.1",
        "@mtcute/markdown-parser": "^0.30.1",
        "@mtcute/wasm": "^0.29.0",
        "@fuman/utils": "0.0.19",
        "@fuman/net": "0.0.19",
        "@fuman/node": "0.0.19",
        "better-sqlite3": "^12.10.0"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.ts",
                "default": "./index.js"
            },
            "require": {
                "types": "./index.d.cts",
                "default": "./index.cjs"
            }
        },
        "./utils.js": {
            "import": {
                "types": "./utils.d.ts",
                "default": "./utils.js"
            },
            "require": {
                "types": "./utils.d.cts",
                "default": "./utils.cjs"
            }
        },
        "./methods.js": {
            "import": {
                "types": "./methods.d.ts",
                "default": "./methods.js"
            },
            "require": {
                "types": "./methods.d.cts",
                "default": "./methods.cjs"
            }
        }
    },
    "author": "alina sireneva <alina@tei.su>",
    "sideEffects": false,
    "homepage": "https://mtcute.dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mtcute/mtcute.git"
    },
    "scripts": {}
}